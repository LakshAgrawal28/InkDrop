# Server
PORT=5000
NODE_ENV=development

# Database - Neon (recommended for production/resume projects)
# Get your connection string from: https://console.neon.tech/
# Example format: postgresql://neondb_owner:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=postgresql://neondb_owner:your-password@ep-nameless-wildflower-a131qmlf-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Database - Local Development (alternative)
# DATABASE_URL=postgresql://username:password@localhost:5432/inkdrop

# JWT Secrets (generate secure random strings)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# JWT Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Cloudinary (optional - for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
